{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "react": ["./node_modules/preact/compat/"],
      "react/jsx-runtime": ["./node_modules/preact/jsx-runtime"],
      "react-dom": ["./node_modules/preact/compat/"],
      "react-dom/*": ["./node_modules/preact/compat/*"]
    },
    // `baseUrl` is deprecated in TS 6 and removed in TS 7. We still need it
    // here because the `paths` keys above are bare module specifiers
    // (`react`, `react-dom`) — without `baseUrl` they resolve relative to
    // each importing file, breaking the alias. Silence the TS 6 deprecation
    // warning until the next major bump forces a rewrite.
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "vite.config.ts"]
}
