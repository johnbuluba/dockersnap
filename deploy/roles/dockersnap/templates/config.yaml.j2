# dockersnap configuration
# Generated by Ansible — do not edit manually.

zfs:
  pool: {{ dockersnap_zfs_pool }}
  dataset_prefix: {{ dockersnap_dataset_prefix }}
  arc_max_bytes: {{ dockersnap_zfs_arc_max_gb * 1073741824 }}

api:
  listen: "{{ dockersnap_api_listen }}"
  token: "{{ dockersnap_api_token }}"
  proxy_bind: "{{ dockersnap_api_proxy_bind }}"

network:
  range: "{{ dockersnap_network_range }}"
  subnet_size: {{ dockersnap_network_subnet_size }}
  base_offset: "{{ dockersnap_network_base_offset }}"
  metallb_host_offset: "{{ dockersnap_network_metallb_offset }}"

docker:
  dns:
{% for dns in dockersnap_docker_dns %}
    - "{{ dns }}"
{% endfor %}
  log_max_size: "50m"
  log_max_file: 3
{% if dockersnap_proxy_http or dockersnap_proxy_https %}
  proxy:
    http: "{{ dockersnap_proxy_http }}"
    https: "{{ dockersnap_proxy_https }}"
    no_proxy: "{{ dockersnap_proxy_no_proxy }}"
{% endif %}

state_file: "{{ dockersnap_state_dir }}/state.json"
run_dir: "{{ dockersnap_run_dir }}"

{% if dockersnap_plugins_enabled %}
plugins:
  dir: {{ dockersnap_plugins_dir }}
  health_poll_interval: "{{ dockersnap_plugins_health_poll_interval }}"
  health_failure_threshold: {{ dockersnap_plugins_health_failure_threshold }}
{% endif %}

